# Server
PORT=5000
NODE_ENV=development

# MongoDB connection string
MONGO_URI=mongodb://127.0.0.1:27017/shopsy

# Auth — set JWT_SECRET to a long random string (e.g. `openssl rand -hex 32`)
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d

# Razorpay (test mode keys from https://dashboard.razorpay.com/app/keys)
# Payment endpoints are disabled until BOTH are set.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
