# Backend origin the Vite dev server proxies "/api" to (read in vite.config.ts).
BACKEND_URL=http://localhost:5000

# Absolute backend API base used by server-side loaders (auth.server.ts).
# Set this in your deployment environment; defaults to the value below in dev.
API_URL=http://localhost:5000/api

# Optional: override the client axios base URL. Leave unset to use the
# same-origin "/api" path (which goes through the dev proxy above).
# VITE_API_URL=
